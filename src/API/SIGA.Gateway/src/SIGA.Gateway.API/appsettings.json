{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceUrls": {
    "UserService": "http://localhost:5001",
    "OrderService": "http://localhost:5002",
    "DeliveryService": "http://localhost:5003"
  },
  "HttpClientPolicy": {
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerTimeoutSeconds": 30
  }
}
